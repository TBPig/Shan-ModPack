	quest.55F36CA8E300692C.title: "再生金属"
	quest.605DAF35FAD6D779.quest_desc: [
		"运用铁锭和石头，制造出导热框架和箱子"
		""
		"将&a箱子&r放于地核之上，再对其使用&a导热框架&r"
		""
		"依赖高温的地核，你们搭建了简单的加热装置"
	]
	quest.605DAF35FAD6D779.title: "简单加热"
	quest.65D3ECBC10F04959.quest_desc: [
		"工匠注意到，当磁矿石靠近缠绕成圈的金属线时，远处的金属碎片竟自行移动——被称为“电流”的力量首次被察觉。"
		""
		"&7建议查看：铁砧工艺指南/电力系统"
		""
		"&7对着集电器等方块长按[G]可以查看如何发电"
	]
	quest.65D3ECBC10F04959.title: "电磁学"
	quest.7BEB7204196444F1.quest_desc: ["飞行对你们来说习以为常，准备好工具后，便可以开始向上挖掘"]
